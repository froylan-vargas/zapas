{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build Zapas.Api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/Zapas.Api/Zapas.Api.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "format",
      "command": "dotnet",
      "type": "process",
      "args": [
        "format",
        "${workspaceFolder}/Zapas.slnx"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
